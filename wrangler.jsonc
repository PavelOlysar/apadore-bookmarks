{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "apadore-bookmarks",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": ".open-next/assets"
  },
  "observability": {
    "enabled": true
  },
  // Preserve dashboard-set Variables and Secrets across deploys.
  // Without this, every `wrangler deploy` wipes the worker's env vars.
  "keep_vars": true
}
